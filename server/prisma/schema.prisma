// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}





// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum role {
  admin
  manager
  team_lead
  front_dev
  back_dev
  qa
  designer
  member
}

enum customer_type {
  individual
  company
}

enum project_status {
  active
  on_hold
  completed
  cancelled
}

enum task_status {
  backlog
  todo
  in_progress
  review
  done
}

enum task_priority {
  low
  medium
  high
  urgent
}

enum log_action {
  created
  updated
  deleted
  login
  logout
  password_changed
  role_changed
  assigned
  unassigned
}

// ─────────────────────────────────────────────────────────────
// MIGRATION 1 — deja existent
// ─────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  phone     String?  @unique
  avatar    String?
  role      role     @default(member)
  googleId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relații
  projectMembers  ProjectMember[]  // proiectele la care participă
  taskAssignees   TaskAssignee[]   // taskurile asignate lui
  createdProjects Project[]        @relation("ProjectCreatedBy")
  createdTasks    Task[]           @relation("TaskCreatedBy")
  createdCustomers Customer[]      @relation("CustomerCreatedBy")
  logs            ActivityLog[]    @relation("LogPerformedBy")
}

// ─────────────────────────────────────────────────────────────
// MIGRATION 2 — Customer
// ─────────────────────────────────────────────────────────────

model Customer {
  id        Int           @id @default(autoincrement())
  type      customer_type @default(individual)

  // Câmpuri comune
  name      String
  email     String?       @unique
  phone     String?       @unique
  address   String?
  notes     String?

  // Câmpuri specifice persoanei juridice
  company   String?       // numele firmei dacă type = company
  vatNumber String?       // CUI / cod fiscal
  regNumber String?       // număr registrul comerțului

  // Câmpuri specifice persoanei fizice
  firstName String?
  lastName  String?

  createdById Int?
  createdBy   User?     @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relații
  projects  Project[]   // proiectele asociate acestui client
}

// ─────────────────────────────────────────────────────────────
// MIGRATION 3 — Project + ProjectMember
// ─────────────────────────────────────────────────────────────

model Project {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  status      project_status @default(active)
  startDate   DateTime?
  dueDate     DateTime?
  budget      Float?

  // Relație opțională cu clientul
  customerId  Int?
  customer    Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdById Int?
  createdBy   User?          @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relații
  members     ProjectMember[]
  tasks       Task[]
}

// Tabel de legătură User <-> Project (many-to-many cu rol în proiect)
model ProjectMember {
  id        Int      @id @default(autoincrement())
  userId    Int
  projectId Int
  role      String   @default("member") // rol specific în proiect: lead, member, observer
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId]) // un user nu poate fi adăugat de două ori în același proiect
}

// ─────────────────────────────────────────────────────────────
// MIGRATION 4 — Task + TaskAssignee
// ─────────────────────────────────────────────────────────────

model Task {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  status      task_status   @default(backlog)
  priority    task_priority @default(medium)
  dueDate     DateTime?

  // Relație opțională cu proiectul — task poate fi de sine stătător
  projectId   Int?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdById Int?
  createdBy   User?         @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relații
  assignees   TaskAssignee[]
}

// Tabel de legătură User <-> Task (many-to-many)
model TaskAssignee {
  id         Int      @id @default(autoincrement())
  userId     Int
  taskId     Int
  assignedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId]) // un user nu poate fi asignat de două ori la același task
}

// ─────────────────────────────────────────────────────────────
// MIGRATION 5 — ActivityLog
// ─────────────────────────────────────────────────────────────

model ActivityLog {
  id           Int        @id @default(autoincrement())

  // Cine a făcut acțiunea
  performedById Int?
  performedBy   User?     @relation("LogPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  // Ce acțiune
  action        log_action

  // Pe ce entitate (ex: "Project", "Task", "User", "Customer")
  entityType    String
  entityId      Int

  // Diff — ce era înainte și ce e după (JSON)
  before        Json?
  after         Json?

  // Metadata
  ip            String?
  userAgent     String?
  note          String?   // mesaj opțional lizibil pentru oameni

  createdAt     DateTime  @default(now())

  @@index([entityType, entityId]) // căutare rapidă după entitate
  @@index([performedById])        // căutare rapidă după user
}


